{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InputLagScope",
  "mainBinaryName": "InputLagScope",
  "version": "1.0.0",
  "identifier": "dev.inputlagscope.latency",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InputLagScope",
        "width": 1200,
        "height": 1080,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
